PORT=4173
PUBLIC_BASE_URL=http://localhost:4173

# Leave DATABASE_URL blank to use local data/db.json.
# For Supabase, use the pooled Postgres connection string here.
# Apply db/schema.sql to the Supabase database first.
DATABASE_URL=

# Optional Supabase values if you later move uploads or auth into the browser.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Cal.com or Cal.diy booking page used by the customer approval page.
CALCOM_BOOKING_URL=
CALDIY_BOOKING_URL=

# Telnyx outbound messaging.
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_WEBHOOK_SIGNING_SECRET=
